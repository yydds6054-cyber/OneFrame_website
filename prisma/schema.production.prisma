// NOTE: Production schema (PostgreSQL). Used by Vercel build only.
// Keep this in sync with prisma/schema.prisma (SQLite, local dev).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  needs     String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}
