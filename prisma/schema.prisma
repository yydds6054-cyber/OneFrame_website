// NOTE: Local dev schema (SQLite). Production uses prisma/schema.production.prisma (Postgres).
// Keep both schemas in sync.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  needs     String
  message   String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}
